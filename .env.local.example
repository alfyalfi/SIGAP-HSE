# Supabase (public — aman untuk client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — JANGAN commit .env.local
SIGAP_DEMO_PASSWORD=your-demo-password
